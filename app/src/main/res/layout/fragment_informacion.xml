<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Los elementos de información sirven para presentar texto, imágenes o procesos de forma visual, permitiendo que se vea el contenido y sea entendible para quien lo ve, pero sin la necesidad de interactuar directamente."
            android:textSize="16sp"
            android:textColor="@android:color/black"
            android:lineSpacingExtra="4dp"
            android:padding="16dp"
            android:backgroundTint="@color/purple2"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Demostración interactiva:"
            android:textSize="16sp"
            android:textColor="@android:color/holo_red_dark"
            android:padding="16dp"/>

        <TextView
            android:id="@+id/txtEstado"
            android:text="Energía baja"
            android:textSize="20sp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <ImageView
            android:id="@+id/imgEstado"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"

            android:src="@android:drawable/ic_dialog_alert"
            android:layout_marginBottom="20dp"/>

        <ProgressBar
            android:id="@+id/progreso"
            style="?android:attr/progressBarStyleHorizontal"
            android:max="100"
            android:progress="0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnCargar"
            android:text="Cargar energía"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="50dp" />

    </LinearLayout>

</ScrollView>